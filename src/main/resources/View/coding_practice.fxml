<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.web.WebView?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" stylesheets="@../Css/coding.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controller.CodingPracticeController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" styleClass="coding-header">
            <Button onAction="#handleBack" styleClass="btn-back" text="❮ Thoát" />
            <Label styleClass="task-title" text="Bài tập: Hello World" />
            <HBox HBox.hgrow="ALWAYS" />
            <Button onAction="#handleRunCode" styleClass="btn-run" text="▶ Chạy thử" />
            <Button onAction="#handleSubmit" styleClass="btn-submit" text="Nộp bài" />
        </HBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.4">
            <AnchorPane>
                <WebView fx:id="webDescription" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0" />
            </AnchorPane>

            <SplitPane orientation="VERTICAL" dividerPositions="0.7">
                <AnchorPane>
                    <WebView fx:id="webCodeEditor" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0" />
                </AnchorPane>

                <VBox styleClass="console-box">
                    <Label styleClass="console-header" text="Kết quả thực thi (Console):" />
                    <TextArea fx:id="txtOutput" editable="false" styleClass="console-text" text="Đang chờ chạy code..." VBox.vgrow="ALWAYS" />
                </VBox>
            </SplitPane>
        </SplitPane>
    </center>
</BorderPane>