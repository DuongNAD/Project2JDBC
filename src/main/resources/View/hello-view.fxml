<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="768.0" prefWidth="1280.0"
           stylesheets="@../Css/global.css"
           xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.example.controller.HelloController">

    <BorderPane>
        <left>
            <fx:include fx:id="sidebar" source="sidebar.fxml" />
        </left>

        <center>
            <StackPane fx:id="contentArea" styleClass="content-area">
                
            </StackPane>
        </center>
    </BorderPane>

    
    <fx:include fx:id="aiChatWidget" source="ai-chat-widget.fxml" StackPane.alignment="BOTTOM_RIGHT" />

</StackPane>