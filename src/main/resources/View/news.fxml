<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<ScrollPane fx:id="mainScrollPane" fitToWidth="true"
            style="-fx-background-color: transparent;"
            styleClass="edge-to-edge"
            stylesheets="@../Css/global.css, @../Css/news.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controller.NewsController">
    <content>
        <VBox>
            <fx:include fx:id="header" source="header.fxml" />

            <VBox styleClass="news-page-container">
                <Button onAction="#handleBack" styleClass="btn-back-stylish" text="❮ Quay lại Trang chủ" />

                <Label styleClass="hero-title" text="📰 Tất cả tin tức công nghệ" />

                <FlowPane fx:id="allNewsContainer" styleClass="news-container-flow" prefWrapLength="1000" />
            </VBox>

        </VBox>
    </content>
</ScrollPane>